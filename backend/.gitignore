# ── Dependencies ───────────────────────────────────────────────────────────
node_modules/

# ── Environment — NEVER commit real secrets ────────────────────────────────
.env
.env.local
.env.*.local

# ── Uploaded files (user data — not for version control) ──────────────────
uploads/*
!uploads/.gitkeep

# ── Logs ───────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Runtime / OS ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ─────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.sw?

# ── Render ─────────────────────────────────────────────────────────────────
.render/
