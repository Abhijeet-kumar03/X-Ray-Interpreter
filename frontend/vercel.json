{
  "rewrites": [
    {
      "source": "/api/:path*/",
      "destination": "https://xray-interpreter-backend.onrender.com//api/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://xray-interpreter-backend.onrender.com//api/:path*"
    },
    {
      "source": "/uploads/:path*/",
      "destination": "https://xray-interpreter-backend.onrender.com//uploads/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://xray-interpreter-backend.onrender.com//uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}